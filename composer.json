{
    "name": "metrial/base-code",
    "type": "project",
    "description": "Production-grade Metrial Base Code (Laravel 12/13): API-first, multi-language (AR/EN), RBAC, governance, event-driven (transactional outbox), payment gateways (Stripe/Paymob/Fawry/PayTabs), wallet ledger, outgoing webhooks, and third-party integration framework.",
    "keywords": ["laravel", "api", "rbac", "ddd", "event-driven", "payments", "governance"],
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "guzzlehttp/guzzle": "^7.8",
        "kreait/firebase-php": "^7.0",
        "laravel/framework": "^12.0",
        "laravel/horizon": "^5.30",
        "laravel/sanctum": "^4.1",
        "laravel/socialite": "^5.28",
        "laravel/tinker": "^2.10",
        "spatie/laravel-permission": "^6.25",
        "spatie/laravel-translatable": "^6.14"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.13",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.1",
        "phpunit/phpunit": "^11.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ],
        "lint": "pint --test",
        "analyse": "phpstan analyse --memory-limit=1G",
        "test": "@php artisan test"
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "platform": {
            "php": "8.3.32"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
