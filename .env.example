APP_NAME="Metrial Base Code"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Africa/Cairo
APP_URL=http://localhost

# ------- Localization -------
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
SUPPORTED_LOCALES=en,ar

# ------- Database (PostgreSQL by default, MySQL also works) -------
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=metrial_base_code
DB_USERNAME=postgres
DB_PASSWORD=secret

# ------- Cache / Queue / Session -------
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=cookie
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ------- Multi-tenancy -------
TENANCY_ENABLED=false
TENANCY_HEADER=X-Tenant

# ------- Governance -------
AUDIT_ENABLED=true
AUDIT_RETENTION_DAYS=365
APPROVALS_ENABLED=true
IDEMPOTENCY_TTL_HOURS=24

# ------- Payments -------
PAYMENT_DEFAULT=stripe
PAYMENT_CURRENCY=EGP

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

PAYMOB_API_KEY=
PAYMOB_INTEGRATION_ID=
PAYMOB_IFRAME_ID=
PAYMOB_HMAC_SECRET=

FAWRY_BASE_URL=https://atfawry.fawrystaging.com
FAWRY_MERCHANT_CODE=
FAWRY_SECURE_KEY=

PAYTABS_BASE_URL=https://secure-egypt.paytabs.com
PAYTABS_PROFILE_ID=
PAYTABS_SERVER_KEY=

# ------- Outgoing webhooks -------
WEBHOOK_MAX_TRIES=5
WEBHOOK_TIMEOUT=10

# ------- SMS providers -------
SMS_DEFAULT=log
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=
VONAGE_KEY=
VONAGE_SECRET=
VONAGE_FROM=

# ------- Push -------
FCM_CREDENTIALS=
FCM_PROJECT_ID=

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
